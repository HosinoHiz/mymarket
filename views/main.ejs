<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MyMarket - 홈</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { display: flex; flex-direction: column; min-height: 100vh; margin: 0; }
        .main-content { flex: 1; }
        .product-img { height: 200px; object-fit: cover; background-color: #f8f9fa; }
        .friend-section { background-color: #f0f8ff; border-radius: 15px; padding: 20px; margin-bottom: 30px; }
        .server-section { background-color: #fff3cd; border: 1px solid #ffeeba; border-radius: 12px; padding: 15px; margin-bottom: 25px; }
        .card { transition: transform 0.2s; }
        .card:hover { transform: translateY(-5px); }
        .btn-xs { padding: 0.25rem 0.4rem; font-size: 0.75rem; }
        .product-title { min-height: 38px; }
    </style>
</head>
<body class="bg-light">

    <!-- 상단 메뉴 -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛒 MyMarket</a>
            
            <div class="ms-auto d-flex align-items-center">
                <% if (user) { %>
                    <span class="text-light me-3 small">안녕하세요, <strong><%= user.userId %></strong>님!</span>
                    
                    <!-- ⭐ 알림 보관함 및 채팅 목록 버튼 -->
                    <a href="/notifications" class="btn btn-warning btn-sm position-relative me-2">
                        🔔 알림
                        <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                <%= notifications.length %>
                            </span>
                        <% } %>
                    </a>
                    <a href="/chat" class="btn btn-success btn-sm me-3">💬 내 채팅</a>
                    
                    <a href="/auth/profile" class="btn btn-info btn-sm me-1">내 정보</a>
                    <a href="/products/write" class="btn btn-primary btn-sm me-1">물품 등록</a>
                    <a href="/auth/logout" class="btn btn-outline-light btn-sm">로그아웃</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-primary btn-sm me-1">로그인</a>
                    <a href="/auth/register" class="btn btn-outline-light btn-sm">회원가입</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="main-content">
        <div class="container">

            <!-- 메인화면 안 읽은 알림 표시 영역 -->
            <% if (typeof notifications !== 'undefined' && notifications.length > 0) { %>
                <div class="alert alert-warning alert-dismissible fade show shadow-sm mb-4" role="alert">
                    <h6 class="alert-heading fw-bold">🔔 새로운 알림이 있습니다!</h6>
                    <ul class="mb-0 mt-2">
                        <% notifications.forEach(noti => { %>
                            <li><%= noti.message %></li>
                        <% }); %>
                    </ul>
                    <form action="/notifications/clear" method="POST" class="d-inline">
                        <button type="submit" class="btn-close" aria-label="Close"></button>
                    </form>
                </div>
            <% } %>

            <div class="server-section shadow-sm">
                <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center">
                    <div>
                        <h5 class="mb-1">🌐 MyMarket 서버 접속 주소</h5>
                        <p class="mb-0 text-muted small">과제 제출용 서버 IP 링크입니다.</p>
                    </div>
                    <div class="mt-3 mt-md-0">
                        <a href="<%= typeof serverUrl !== 'undefined' ? serverUrl : 'http://136.119.7.198:3000' %>" target="_blank" class="btn btn-warning fw-bold">서버 접속하기</a>
                    </div>
                </div>
            </div>

            <% if (!user) { %>
                <div class="alert alert-primary shadow-sm">로그인하면 물품 등록, 수정, 삭제, 친구추가, 채팅 기능을 사용할 수 있습니다.</div>
            <% } %>

            <% if (user) { %>
                <div class="friend-section shadow-sm border border-info">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="mb-0 text-info">🤝 친구들이 올린 최신 물품 3개</h4>
                        <span class="badge bg-info text-dark">가산점 기능</span>
                    </div>

                    <% if (typeof friendProducts !== 'undefined' && friendProducts.length > 0) { %>
                        <div class="row">
                            <% friendProducts.forEach(product => { %>
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100 border-info">
                                        <div class="card-header bg-info text-white text-center py-1 small">친구 추천 매물</div>
                                        <img src="<%= product.imagePath || 'https://via.placeholder.com/300x200?text=No+Image' %>" class="card-img-top product-img" alt="상품이미지">
                                        <div class="card-body">
                                            <h5 class="card-title text-truncate fs-6 product-title"><%= product.title %></h5>
                                            <p class="card-text text-primary fw-bold mb-1"><%= Number(product.price || 0).toLocaleString() %>원</p>
                                            <p class="card-text small text-muted mb-1">판매자: <%= product.ownerName || '알 수 없음' %></p>
                                            <% if (product.status === 'soldout') { %>
                                                <span class="badge bg-secondary">판매완료</span>
                                            <% } else { %>
                                                <span class="badge bg-success">판매중</span>
                                            <% } %>
                                        </div>
                                        <div class="card-footer bg-white border-top-0">
                                            <a href="/products/detail/<%= product.id %>" class="btn btn-sm btn-info w-100 text-white">상세보기</a>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        </div>
                    <% } else { %>
                        <div class="bg-white border rounded p-4 text-center">
                            <p class="text-muted mb-1">아직 친구가 없거나 친구가 등록한 물품이 없습니다.</p>
                        </div>
                    <% } %>
                </div>
            <% } %>

            <div class="all-products pb-5">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h3 class="mb-0">📦 전체 판매 물품</h3>
                </div>

                <div class="row">
                    <% if (typeof allProducts !== 'undefined' && allProducts.length > 0) { %>
                        <% allProducts.forEach(product => { %>
                            <div class="col-md-3 col-sm-6 mb-4">
                                <div class="card h-100 shadow-sm">
                                    <img src="<%= product.imagePath || 'https://via.placeholder.com/300x200?text=No+Image' %>" class="card-img-top product-img" alt="상품이미지">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <h5 class="card-title text-truncate fs-6 product-title mb-0"><%= product.title %></h5>
                                            <% if (product.status === 'soldout') { %>
                                                <span class="badge bg-secondary ms-1">완료</span>
                                            <% } else { %>
                                                <span class="badge bg-success ms-1">판매중</span>
                                            <% } %>
                                        </div>
                                        <p class="card-text text-danger fw-bold mb-1"><%= Number(product.price || 0).toLocaleString() %>원</p>
                                        <p class="card-text small text-muted mb-0">판매자: <%= product.ownerName || '알 수 없음' %></p>
                                    </div>
                                    <div class="card-footer bg-white border-top-0 pb-3">
                                        <div class="d-grid gap-2">
                                            <a href="/products/detail/<%= product.id %>" class="btn btn-sm btn-outline-secondary">상세보기</a>
                                            <% if (user && user.id === product.userId) { %>
                                                <div class="btn-group w-100">
                                                    <a href="/products/edit/<%= product.id %>" class="btn btn-warning btn-xs text-dark">수정</a>
                                                    <a href="/products/delete/<%= product.id %>" class="btn btn-danger btn-xs" onclick="return confirm('정말 삭제하시겠습니까?')">삭제</a>
                                                </div>
                                            <% } else if (user && user.id !== product.userId) { %>
                                                <a href="/add-friend/<%= product.userId %>" class="btn btn-sm btn-outline-primary" onclick="return confirm('이 판매자를 친구로 추가하시겠습니까?')">판매자 친구추가</a>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="col-12 text-center py-5">
                            <div class="card py-5 bg-white shadow-sm">
                                <p class="text-muted mb-0">등록된 판매 물품이 없습니다.</p>
                                <% if (user) { %>
                                    <div class="mt-3"><a href="/products/write" class="btn btn-success">물품 등록하기</a></div>
                                <% } else { %>
                                    <div class="mt-3"><a href="/auth/login" class="btn btn-primary">로그인하기</a></div>
                                <% } %>
                            </div>
                        </div>
                    <% } %>
                </div>
            </div>

        </div>
    </div>

    <footer class="bg-dark text-white text-center py-3 mt-auto shadow-lg">
        <div class="container">
            <small>&copy; 2026 MyMarket Project. All Rights Reserved.</small>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>