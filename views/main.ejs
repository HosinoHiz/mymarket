<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>MyMarket - 홈</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body { display: flex; flex-direction: column; min-height: 100vh; margin: 0; } .main-content { flex: 1; } .product-img { height: 200px; object-fit: cover; background-color: #f8f9fa; } .card:hover { transform: translateY(-5px); }</style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛒 MyMarket</a>
            <div class="ms-auto d-flex align-items-center">
                <% if (user) { %>
                    <span class="text-light me-3 small">
                        <strong><%= user.userId %></strong>님!
                        <span class="badge bg-warning text-dark ms-2" style="font-size:14px;">💰 <%= typeof userBalance !== 'undefined' ? Number(userBalance).toLocaleString() : 0 %>원</span>
                    </span>
                    <a href="/cart" class="btn btn-secondary btn-sm me-2">🛒 장바구니</a>
                    
                    <a href="/notifications" class="btn btn-danger btn-sm position-relative me-2">
                        🔔 <span id="noti-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark" style="display: none;">0</span>
                    </a>
                    <a href="/chat" class="btn btn-success btn-sm me-3">💬</a>
                    <a href="/auth/profile" class="btn btn-info btn-sm me-1">내 정보</a>
                    <a href="/products/write" class="btn btn-primary btn-sm me-1">등록</a>
                    <a href="/auth/logout" class="btn btn-outline-light btn-sm">로그아웃</a>
                <% } else { %>
                    <a href="/auth/login" class="btn btn-primary btn-sm me-1">로그인</a>
                    <a href="/auth/register" class="btn btn-outline-light btn-sm">회원가입</a>
                <% } %>
            </div>
        </div>
    </nav>
    <div class="main-content">
        <div class="container">
            <h3 class="mb-4 fw-bold">📦 전체 판매 물품</h3>
            <div class="row">
                <% if (typeof allProducts !== 'undefined' && allProducts.length > 0) { %>
                    <% allProducts.forEach(product => { %>
                        <div class="col-md-3 mb-4">
                            <div class="card h-100 shadow-sm border-0">
                                <img src="<%= product.imagePath || 'https://via.placeholder.com/300x200?text=No+Image' %>" class="card-img-top product-img">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="fw-bold text-truncate"><%= product.title %></h6>
                                        <% if (product.status === 'soldout') { %><span class="badge bg-secondary">완료</span>
                                        <% } else if (product.status === 'reserved') { %><span class="badge bg-warning text-dark">예약중</span>
                                        <% } else { %><span class="badge bg-success">판매중</span><% } %>
                                    </div>
                                    <p class="text-danger fw-bold mb-1"><%= Number(product.price || 0).toLocaleString() %>원</p>
                                    <p class="small text-muted mb-0">👁 조회: <%= product.views %> | 판매자: <%= product.ownerName %></p>
                                </div>
                                <div class="card-footer bg-white pb-3 border-0">
                                    <a href="/products/detail/<%= product.id %>" class="btn btn-sm btn-outline-secondary w-100">상세보기</a>
                                </div>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <p class="text-center text-muted py-5">물품이 없습니다.</p>
                <% } %>
            </div>
        </div>
    </div>
    
    <script>
        <% if (user) { %>
            function checkNotifications() {
                fetch('/api/noti-check')
                    .then(res => res.json())
                    .then(data => {
                        const badge = document.getElementById('noti-badge');
                        if (data.count > 0) {
                            badge.innerText = data.count;
                            badge.style.display = 'inline-block';
                        } else {
                            badge.style.display = 'none';
                        }
                    })
                    .catch(err => console.error(err));
            }
            
            // 페이지 접속 시 즉시 1번 실행하고, 이후 3초마다 계속 감시
            checkNotifications();
            setInterval(checkNotifications, 3000);
        <% } %>
    </script>
</body>
</html>