<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>로그인 - MyMarket</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }

        .login-card {
            max-width: 420px;
            margin: 0 auto;
        }
    </style>
</head>

<body>
    <nav class="navbar navbar-dark bg-dark mb-5">
        <div class="container">
            <a href="/" class="navbar-brand fw-bold">🛒 MyMarket</a>
            <div>
                <a href="/" class="btn btn-outline-light btn-sm">홈으로</a>
            </div>
        </div>
    </nav>

    <div class="container">
        <div class="card shadow login-card">
            <div class="card-header bg-primary text-white text-center">
                <h3 class="mb-0">로그인</h3>
            </div>

            <div class="card-body p-4">
                <form action="/auth/login" method="POST">

                    <div class="mb-3">
                        <label class="form-label fw-bold">아이디</label>
                        <input type="text"
                               name="userId"
                               class="form-control"
                               placeholder="아이디를 입력하세요"
                               required>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">비밀번호</label>
                        <input type="password"
                               name="password"
                               class="form-control"
                               placeholder="비밀번호를 입력하세요"
                               required>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        로그인
                    </button>

                </form>

                <hr>

                <div class="text-center">
                    <p class="text-muted small mb-2">
                        아직 계정이 없으신가요?
                    </p>
                    <a href="/auth/register" class="btn btn-outline-success w-100">
                        회원가입
                    </a>
                </div>

                <div class="text-center mt-3">
                    <a href="/" class="text-decoration-none text-muted small">
                        메인으로 돌아가기
                    </a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>