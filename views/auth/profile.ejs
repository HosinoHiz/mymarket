<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>내 정보 - MyMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-5">
        <div class="container"><a href="/" class="navbar-brand fw-bold">🛒 MyMarket</a><a href="/" class="btn btn-outline-light btn-sm">홈으로</a></div>
    </nav>
    <div class="container mb-5" style="max-width: 700px;">
        <div class="card shadow border-0">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">👤 내 지갑 및 정보</h4>
                <a href="/auth/profile/edit" class="btn btn-sm btn-light">정보 수정</a>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0 text-dark fw-bold">💰 나의 보유 금액</h5>
                    <h4 class="mb-0 text-danger fw-bold"><%= Number(profile.balance).toLocaleString() %> 원</h4>
                </div>
                <div class="mb-2 d-flex"><div style="width:100px;" class="fw-bold text-muted">아이디</div><div><%= profile.userId %></div></div>
                <div class="mb-4 d-flex"><div style="width:100px;" class="fw-bold text-muted">회원 번호</div><div>#<%= profile.id %></div></div>
                <hr>

                <h5 class="fw-bold mb-3 text-primary">🤝 내 물건에 들어온 흥정 요청</h5>
                <% if (typeof receivedBargains !== 'undefined' && receivedBargains.length > 0) { %>
                    <ul class="list-group mb-4">
                        <% receivedBargains.forEach(b => { %>
                            <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                                <div><strong class="fs-5">[<%= b.title %>]</strong><br><span class="text-muted"><%= b.buyerName %>님의 제안: </span><span class="text-danger fw-bold fs-5"><%= Number(b.offerPrice).toLocaleString() %>원</span></div>
                                <div><a href="/products/bargain/accept/<%= b.id %>" class="btn btn-success fw-bold me-1" onclick="return confirm('수락하시겠습니까?')">수락</a><a href="/products/bargain/reject/<%= b.id %>" class="btn btn-outline-danger">거절</a></div>
                            </li>
                        <% }) %>
                    </ul>
                <% } else { %><div class="bg-light rounded p-4 text-center text-muted mb-4 border">대기 중인 요청이 없습니다.</div><% } %>

                <hr>
                <h5 class="fw-bold mb-3 text-success">🛍️ 내가 구매한 물품 내역</h5>
                <% if (typeof purchasedProducts !== 'undefined' && purchasedProducts.length > 0) { %>
                    <div class="row">
                        <% purchasedProducts.forEach(p => { %>
                            <div class="col-md-6 mb-3">
                                <div class="card h-100 border-success">
                                    <div class="card-body">
                                        <h6 class="fw-bold text-truncate"><%= p.title %></h6>
                                        <p class="text-danger mb-0"><%= Number(p.price).toLocaleString() %>원 결제됨</p>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } else { %>
                    <div class="bg-light rounded p-4 text-center text-muted border">아직 구매한 물품이 없습니다. 쇼핑을 즐겨보세요!</div>
                <% } %>

            </div>
        </div>
    </div>
</body>
</html>