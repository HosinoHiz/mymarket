<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>내 알림 보관함</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width: 600px;">
        <div class="card shadow">
            <div class="card-header bg-warning text-dark d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">🔔 내 알림 보관함</h5>
                <a href="/" class="btn btn-sm btn-light border">홈으로</a>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <% if (notifications.length === 0) { %>
                        <li class="list-group-item text-center text-muted py-5">도착한 알림이 없습니다.</li>
                    <% } else { %>
                        <% notifications.forEach(noti => { %>
                            <li class="list-group-item p-3 <%= noti.isRead ? 'bg-light text-muted' : 'fw-bold' %>">
                                <div class="d-flex w-100 justify-content-between">
                                    <span style="font-size: 15px;"><%= noti.message %></span>
                                    <small class="text-secondary"><%= new Date(noti.createdAt).toLocaleString() %></small>
                                </div>
                            </li>
                        <% }) %>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>