<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>내 채팅 목록</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <div class="container mt-5" style="max-width: 600px;">
        <div class="card shadow">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">💬 내 채팅방 목록</h5>
                <a href="/" class="btn btn-sm btn-light">홈으로</a>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <% if (chatUsers.length === 0) { %>
                        <li class="list-group-item text-center text-muted py-5">진행 중인 채팅이 없습니다.</li>
                    <% } else { %>
                        <% chatUsers.forEach(u => { %>
                            <a href="/chat/<%= u.id %>" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center p-3">
                                <span class="fw-bold"><%= u.userId %>님과의 대화</span>
                                <span class="badge bg-primary rounded-pill">입장하기</span>
                            </a>
                        <% }) %>
                    <% } %>
                </ul>
            </div>
        </div>
    </div>
</body>
</html>