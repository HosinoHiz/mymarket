<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title><%= product.title %> - 상세보기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        .detail-img { max-height: 500px; width: 100%; object-fit: contain; background-color: #f8f9fa; }
    </style>
</head>
<body class="bg-light">
    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8 card shadow p-0">
                <img src="<%= product.imagePath || 'https://via.placeholder.com/600x400?text=No+Image' %>" class="detail-img card-img-top">
                
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h2 class="fw-bold text-truncate" style="max-width: 70%;"><%= product.title %></h2>
                        <h3 class="text-danger"><%= product.price.toLocaleString() %>원</h3>
                    </div>
                    
                    <hr>
                    <p class="text-muted mb-4" style="white-space: pre-line;"><%= product.content %></p>
                    <hr>

                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary">
                            판매자: <strong><%= product.ownerName %></strong>
                            
                            <% if (user && user.id !== product.userId) { %>
                                <% if (typeof isFriend !== 'undefined' && isFriend) { %>
                                    <button class="btn btn-sm btn-secondary ms-2" disabled>
                                        <i class="bi bi-person-check-fill"></i> 이미 친구입니다
                                    </button>
                                <% } else { %>
                                    <a href="/add-friend/<%= product.userId %>" class="btn btn-sm btn-outline-info ms-2">
                                        <i class="bi bi-person-plus"></i> 친구추가
                                    </a>
                                <% } %>
                            <% } %>
                        </span>
                        
                        <div class="d-flex gap-2">
                            <a href="/" class="btn btn-outline-secondary">목록으로</a>
                            
                            <% if (user) { %> 
                                <% if (user.id === product.userId) { %>
                                    <a href="/products/edit/<%= product.id %>" class="btn btn-warning">수정</a>
                                    <a href="/products/delete/<%= product.id %>" class="btn btn-danger" onclick="return confirm('삭제하시겠습니까?')">삭제</a>
                                <% } else { %>
                                    <button class="btn btn-primary" onclick="buyProduct('<%= product.id %>')">구매하기</button>
                                    <a href="/chat/<%= product.userId %>" class="btn btn-success">판매자와 채팅</a>
                                <% } %>
                            <% } else { %>
                                <a href="/auth/login" class="btn btn-primary">로그인 후 이용 가능</a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
    function buyProduct(id) {
        if(confirm('이 물건을 구매하시겠습니까? 판매자에게 알림이 전송됩니다.')) {
            location.href = '/products/buy/' + id;
        }
    }
    </script>
</body>
</html>