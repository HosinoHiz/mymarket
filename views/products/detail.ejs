<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title><%= product.title %> - 상세보기</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>body{background-color:#f8f9fa;}.detail-img{max-height:500px;width:100%;object-fit:contain;background-color:#fff;border-bottom:1px solid #dee2e6;}</style>
</head>
<body>
    <div class="container mt-5 mb-5">
        <div class="card shadow p-0 col-md-8 mx-auto">
            <img src="<%= product.imagePath || 'https://via.placeholder.com/600x400?text=No+Image' %>" class="detail-img card-img-top">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h2 class="fw-bold mb-0"><%= product.title %> <% if (product.status === 'soldout') { %><span class="badge bg-secondary fs-6 align-middle">판매완료</span><% } %></h2>
                    <h3 class="text-danger mb-0"><%= Number(product.price).toLocaleString() %>원</h3>
                </div>
                <p class="text-muted small">👁 조회수: <%= product.views %> | 📍 지역: <%= product.location || '정보없음' %></p>
                <hr>
                <p style="white-space: pre-line; min-height: 100px;"><%= product.content %></p>
                <hr>
                
                <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded mb-4">
                    <span class="text-secondary">판매자: <strong><%= product.ownerName %></strong></span>
                    <% if (user && user.id !== product.userId) { %>
                        <a href="/chat/<%= product.userId %>" class="btn btn-sm btn-success">💬 1:1 채팅</a>
                    <% } %>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a href="/" class="btn btn-outline-secondary">목록으로</a>
                    <% if (user) { %>
                        <% if (user.id === product.userId) { %>
                            <a href="/products/edit/<%= product.id %>" class="btn btn-warning">수정</a>
                            <a href="/products/delete/<%= product.id %>" class="btn btn-danger" onclick="return confirm('삭제할까요?')">삭제</a>
                        <% } else { %>
                            <% if (product.status === 'soldout') { %>
                                <button class="btn btn-secondary" disabled>판매완료 됨</button>
                            <% } else { %>
                                <button class="btn btn-warning" onclick="requestBargain('<%= product.id %>', <%= product.price %>)">🤝 더 싸게 흥정하기</button>
                                <button class="btn btn-primary" onclick="buyProduct('<%= product.id %>', <%= product.price %>)">💳 정가로 바로구매</button>
                            <% } %>
                        <% } %>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        function buyProduct(id, price) {
            if (confirm(`정가 ${price.toLocaleString()}원에 바로 결제하여 구매하시겠습니까?\n(보유 금액에서 즉시 차감됩니다)`)) {
                location.href = '/products/buy/' + id;
            }
        }

        // ⭐ 흥정 스크립트 추가
        function requestBargain(id, originalPrice) {
            const price = prompt(`현재 가격: ${originalPrice.toLocaleString()}원\n원하시는 흥정 가격을 입력하세요 (숫자만):`);
            if (price) {
                const numPrice = Number(price);
                if (isNaN(numPrice) || numPrice < 0) return alert('올바른 숫자를 입력해주세요.');
                if (numPrice >= originalPrice) return alert('원래 가격보다 낮은 가격을 입력하셔야 흥정입니다!');
                
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '/products/bargain/' + id;
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'offerPrice';
                input.value = numPrice;
                form.appendChild(input);
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
</body>
</html>