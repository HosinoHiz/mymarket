<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>물품 등록 - MyMarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛒 MyMarket</a>
            <div>
                <a href="javascript:history.back()" class="btn btn-outline-light btn-sm me-2">🔙 뒤로가기</a>
                <a href="/" class="btn btn-primary btn-sm">🏠 홈으로</a>
            </div>
        </div>
    </nav>

    <div class="container" style="max-width: 600px;">
        <div class="card shadow border-0 mb-5">
            <div class="card-header bg-primary text-white"><h5 class="mb-0">📦 내 물건 팔기</h5></div>
            <div class="card-body p-4">
                
                <form action="/products/write" method="POST" enctype="multipart/form-data" onsubmit="return preventDoubleSubmit()">
                    <div class="mb-3">
                        <label class="form-label fw-bold">상품 제목</label>
                        <input type="text" name="title" class="form-control" required placeholder="예) 아이폰 15 프로 팝니다">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">판매 가격 (원)</label>
                        <input type="number" name="price" class="form-control" min="0" max="999999999" required placeholder="숫자만 입력">
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold text-danger">상품 이미지 (필수 📸)</label>
                        <input type="file" name="document" class="form-control" accept="image/*" required id="productImage">
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">상세 설명</label>
                        <textarea name="content" class="form-control" rows="5" placeholder="상품의 상태, 직거래 지역 등을 자세히 적어주세요."></textarea>
                    </div>
                    <div class="d-grid">
                        <button type="submit" id="submitBtn" class="btn btn-primary btn-lg fw-bold">상품 등록하기</button>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <script>
        // ⭐ 연타 방지 스크립트
        let isSubmitting = false;

        function preventDoubleSubmit() {
            const imgInput = document.getElementById('productImage');
            if (!imgInput.value) {
                alert('상품 이미지를 반드시 첨부해주세요!');
                return false;
            }

            // 이미 제출 중이면 무시 (연타 완벽 방어)
            if (isSubmitting) return false; 
            
            isSubmitting = true;
            const btn = document.getElementById('submitBtn');
            btn.innerText = '등록 중입니다 ⏳...';
            btn.classList.replace('btn-primary', 'btn-secondary');
            btn.style.pointerEvents = 'none'; // 마우스 클릭 원천 차단
            
            return true;
        }
    </script>
</body>
</html>