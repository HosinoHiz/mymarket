<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title><%= seller.userId %>님과의 채팅</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <nav class="navbar navbar-dark bg-dark mb-4 shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">🛒 MyMarket</a>
            <div>
                <a href="/chat" class="btn btn-outline-light btn-sm me-2">🔙 채팅 목록</a>
                <a href="/" class="btn btn-primary btn-sm">🏠 홈으로</a>
            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5" style="max-width: 600px;">
        
        <div class="card shadow-sm border-0 mb-3 bg-white">
            <div class="card-body p-3 d-flex justify-content-between align-items-center bg-warning bg-opacity-10 rounded">
                <div><span class="fw-bold"><%= seller.userId %></span>님에게 송금하기</div>
                <form action="/auth/transfer" method="POST" class="d-flex gap-2 m-0" onsubmit="return confirm('<%= seller.userId %>님에게 송금하시겠습니까?')">
                    <input type="hidden" name="targetUserId" value="<%= seller.userId %>">
                    <input type="number" name="amount" class="form-control form-control-sm" placeholder="금액 입력" required min="1" style="width: 120px;">
                    <button type="submit" class="btn btn-warning btn-sm fw-bold text-dark" style="white-space: nowrap;">💸 송금</button>
                </form>
            </div>
        </div>

        <div class="card shadow border-0">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">💬 <%= seller.userId %>님과의 대화</h5>
            </div>
            
            <div class="card-body" id="chat-history" style="height: 450px; overflow-y: auto; background-color: #e9ecef;">
                <% if (messages.length === 0) { %>
                    <div class="text-center text-muted mt-5">첫 인사를 건네보세요!</div>
                <% } %>

                <% messages.forEach(msg => { %>
                    <div class="mb-3 <%= msg.senderId === myId ? 'text-end' : 'text-start' %>">
                        <div class="small text-muted mb-1 fw-bold">
                            <%= msg.senderId === myId ? '나' : msg.senderName %>
                        </div>
                        <span class="badge <%= msg.senderId === myId ? 'bg-warning text-dark' : 'bg-white text-dark border' %> text-wrap text-start shadow-sm" style="font-size: 15px; max-width: 80%; padding: 10px;">
                            <%= msg.content %>
                        </span>
                    </div>
                <% }) %>
            </div>

            <div class="card-footer bg-white border-0 py-3">
                <form action="/chat/<%= seller.id %>" method="POST" class="d-flex" autocomplete="off">
                    <input type="text" name="content" class="form-control me-2" placeholder="메시지를 입력하세요" required autofocus>
                    <button type="submit" class="btn btn-success px-4 fw-bold">전송</button>
                </form>
            </div>
        </div>
    </div>

    <script>
        const chatHistory = document.getElementById('chat-history');
        chatHistory.scrollTop = chatHistory.scrollHeight;

        setInterval(() => {
            fetch(location.href)
                .then(response => response.text())
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newChatHtml = doc.getElementById('chat-history').innerHTML;
                    
                    if (chatHistory.innerHTML !== newChatHtml) {
                        const isAtBottom = chatHistory.scrollHeight - chatHistory.clientHeight <= chatHistory.scrollTop + 10;
                        chatHistory.innerHTML = newChatHtml;
                        if (isAtBottom) chatHistory.scrollTop = chatHistory.scrollHeight;
                    }
                })
                .catch(err => console.error('채팅 새로고침 오류:', err));
        }, 2000);
    </script>
</body>
</html>